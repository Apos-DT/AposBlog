# 复制为 .env 并填入真实值（.env 不要提交到 git）
PORT=3000

# DeepSeek（OpenAI 兼容）—— AI 对话用，key 只存服务器，绝不进前端/git
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 管理口令 —— 前端「设置」页登录后才能增删改文章、删除留言
ADMIN_TOKEN=change-me-to-a-strong-secret

# AI 限流
AI_DAILY_LIMIT=20
AI_MSG_MAXLEN=2000

# SQLite 数据库路径
DB_PATH=./data.db
